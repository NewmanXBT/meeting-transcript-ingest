# Obsidian destinations
OBSIDIAN_SOURCES_DIR="~/Documents/Obsidian Vault/ZeroDrift Material Library/sources/meetings"
OBSIDIAN_INTERNAL_DIR="~/Documents/Obsidian Vault/ZeroDrift Wiki/raw/internal"

# Google Meet API OAuth
# Save your OAuth desktop client JSON at:
# ./state/google-oauth-client.json

# Lark/Feishu Minutes API
# Prefer a user_access_token for search. A tenant token can work for export if app permissions cover the Minutes file.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ACCESS_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ACCESS_TOKEN=

# Optional OpenAI summary and high-accuracy transcription
OPENAI_API_KEY=
MEETING_NOTES_MODEL=gpt-4o
MEETING_SUMMARY_MAX_CHARS=120000
MEETING_SUMMARY_MAX_OUTPUT_TOKENS=2400
